# =============================================================================
# FinOpsKit for AWS — Configuración de Variables de Entorno
# =============================================================================
# Copie este archivo como .env y complete sus valores.
# ¡NUNCA suba el archivo .env a GitHub!
#
# Si deja AWS_ACCESS_KEY_ID y AWS_SECRET_ACCESS_KEY vacíos,
# la aplicación usará la carpeta .aws/ (legacy) como respaldo.
# =============================================================================

# ── Región AWS por defecto ──────────────────────────────────────────────────
AWS_DEFAULT_REGION=us-east-1

# ── Credenciales de AWS (Access Key + Secret Key) ───────────────────────────
# Estas credenciales deben tener los permisos descritos en la documentación.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── Perfil de AWS (opcional, por defecto "default") ─────────────────────────
# Útil si tiene múltiples perfiles configurados en ~/.aws/credentials
# AWS_PROFILE=produccion

# ── Bucket S3 para respaldos ────────────────────────────────────────────────
# Nombre del bucket S3 donde se exportarán los snapshots de RDS.
# El bucket debe existir y tener los permisos adecuados.
S3_BACKUP_BUCKET=
